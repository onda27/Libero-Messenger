rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function validUsername(name) {
      return name.matches('^[a-z0-9]{3,20}$');
    }

    function validTextMessage() {
      return request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 4000
        && (!('type' in request.resource.data) || request.resource.data.type == 'text');
    }

    function validImageMessage() {
      return request.resource.data.type == 'image'
        && request.resource.data.imageUrl is string
        && request.resource.data.imageUrl.size() > 0
        && request.resource.data.text is string
        && request.resource.data.text.size() <= 500
        && (!('encKeyB64' in request.resource.data) || request.resource.data.encKeyB64 is string);
    }

    function validCallMessage() {
      return request.resource.data.type == 'call'
        && request.resource.data.callType is string
        && request.resource.data.callStatus is string
        && request.resource.data.isRead == true;
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId)
        && request.resource.data.uid == userId
        && validUsername(request.resource.data.username);
      allow update: if isOwner(userId);
      allow delete: if false;
    }

    match /users_by_username/{username} {
      allow read: if true;
      allow create: if isSignedIn()
        && validUsername(username)
        && request.resource.data.uid == request.auth.uid;
      allow update, delete: if false;
    }

    match /friend_requests/{requestId} {
      allow read: if isSignedIn() && (
        resource.data.senderUid == request.auth.uid ||
        resource.data.receiverUid == request.auth.uid
      );
      allow create: if isSignedIn()
        && request.resource.data.senderUid == request.auth.uid
        && request.resource.data.status == 'pending';
      allow update: if isSignedIn() && (
        resource.data.receiverUid == request.auth.uid ||
        resource.data.senderUid == request.auth.uid
      );
      allow delete: if isSignedIn() && (
        resource.data.receiverUid == request.auth.uid ||
        resource.data.senderUid == request.auth.uid
      );
    }

    match /messages/{messageId} {
      allow read: if isSignedIn() && (
        resource.data.senderUid == request.auth.uid ||
        resource.data.receiverUid == request.auth.uid
      );
      allow create: if isSignedIn()
        && request.resource.data.senderUid == request.auth.uid
        && request.resource.data.receiverUid is string
        && request.resource.data.receiverUid != request.auth.uid
        && request.resource.data.createdAt is number
        && (request.resource.data.isRead == false || validCallMessage())
        && (validTextMessage() || validImageMessage() || validCallMessage());
      allow update: if isSignedIn() && resource.data.receiverUid == request.auth.uid;
      allow delete: if isSignedIn() && (
        resource.data.senderUid == request.auth.uid ||
        resource.data.receiverUid == request.auth.uid
      );
    }

    // WebRTC Call signaling
    // ICE candidates are stored directly in the call document
    // as arrays: callerCandidates and receiverCandidates
    match /calls/{callId} {
      allow read: if isSignedIn() && (
        resource.data.callerUid == request.auth.uid ||
        resource.data.receiverUid == request.auth.uid
      );
      allow create: if isSignedIn()
        && request.resource.data.callerUid == request.auth.uid
        && request.resource.data.receiverUid is string
        && request.resource.data.receiverUid != request.auth.uid
        && request.resource.data.status == 'ringing'
        && request.resource.data.createdAt is number;
      allow update: if isSignedIn() && (
        resource.data.callerUid == request.auth.uid ||
        resource.data.receiverUid == request.auth.uid
      );
      allow delete: if false;
    }
  }
}
